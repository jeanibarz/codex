{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "definitions": {
    "CodexHookCapabilitiesWire": {
      "additionalProperties": false,
      "properties": {
        "handler_features": {
          "$ref": "#/definitions/CodexHookHandlerFeaturesWire"
        },
        "supported_events": {
          "items": {
            "$ref": "#/definitions/HookEventNameWire"
          },
          "type": "array"
        },
        "surface_version": {
          "format": "uint32",
          "minimum": 0.0,
          "type": "integer"
        }
      },
      "required": [
        "handler_features",
        "supported_events",
        "surface_version"
      ],
      "type": "object"
    },
    "CodexHookHandlerFeaturesWire": {
      "additionalProperties": false,
      "properties": {
        "command_if": {
          "type": "boolean"
        }
      },
      "required": [
        "command_if"
      ],
      "type": "object"
    },
    "HookEventNameWire": {
      "enum": [
        "PreToolUse",
        "PostToolUse",
        "PostToolUseFailure",
        "Notification",
        "SessionStart",
        "SessionEnd",
        "UserPromptSubmit",
        "Stop",
        "StopFailure",
        "PermissionRequest"
      ],
      "type": "string"
    },
    "NullableString": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "properties": {
    "codex_hook_capabilities": {
      "$ref": "#/definitions/CodexHookCapabilitiesWire"
    },
    "cwd": {
      "type": "string"
    },
    "hook_event_name": {
      "const": "SessionStart",
      "type": "string"
    },
    "model": {
      "type": "string"
    },
    "permission_mode": {
      "enum": [
        "default",
        "acceptEdits",
        "plan",
        "dontAsk",
        "bypassPermissions"
      ],
      "type": "string"
    },
    "session_id": {
      "type": "string"
    },
    "source": {
      "enum": [
        "startup",
        "resume",
        "clear"
      ],
      "type": "string"
    },
    "transcript_path": {
      "$ref": "#/definitions/NullableString"
    }
  },
  "required": [
    "codex_hook_capabilities",
    "cwd",
    "hook_event_name",
    "model",
    "permission_mode",
    "session_id",
    "source",
    "transcript_path"
  ],
  "title": "session-start.command.input",
  "type": "object"
}